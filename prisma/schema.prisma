// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id        String    @id @default(cuid())
  shop      String
  sessionId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String
  content        String
  createdAt      DateTime     @default(now())
}

// Per-shop settings, billing state, and usage tracking.
// One row per shop — upserted on first chat or admin load.
model ShopSettings {
  id              String    @id @default(cuid())
  shop            String    @unique
  // Billing
  plan            String    @default("free")   // "free" | "pro"
  billingId       String?                       // Shopify subscription GID
  // Freemium usage (reset monthly)
  messageCount    Int       @default(0)
  lastReset       DateTime  @default(now())
  // Review system
  reviewPrompted  Boolean   @default(false)     // legacy — kept for compat
  reviewRequestedAt   DateTime?                 // last time review modal was shown
  reviewDismissedCount Int   @default(0)        // how many times merchant dismissed
  hasReviewed     Boolean   @default(false)     // merchant clicked "Leave a review"
  // Counters for smart triggers
  aiHandledChats  Int       @default(0)         // chats fully handled by AI (no escalation)
  orderTrackingResolved Int @default(0)         // order tracking queries answered
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Knowledge Base entries — store policies fetched from Shopify on install,
// plus any custom FAQs the merchant adds manually.
model KnowledgeBase {
  id        String   @id @default(cuid())
  shop      String
  title     String                         // "Return Policy", "Shipping Policy", etc.
  content   String                         // full policy text (can be long)
  type      String   @default("custom")    // "refund_policy" | "shipping_policy" | "privacy_policy" | "terms_of_service" | "custom"
  status    String   @default("active")    // "active" | "draft"
  source    String   @default("manual")    // "shopify_import" | "manual"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([shop, type])                    // policy deduplication done at app layer via upsert
}

// Revenue attribution — tracks which product card clicks in chat
// led to a completed order within a 24-hour attribution window.
// One row per product click; order_id / attributed_revenue filled
// in by the ORDERS_CREATE webhook when a match is found.
model ChatAttribution {
  id                 String    @id @default(cuid())
  shop               String
  conversationId     String
  productId          String                          // Shopify GID, e.g. "gid://shopify/Product/123"
  productHandle      String                          // for leaderboard display
  productTitle       String
  clickedAt          DateTime  @default(now())
  orderId            String?                         // Shopify order GID, set on attribution
  orderValue         Float?                          // total order value (for reference)
  attributedRevenue  Float?                          // revenue attributed to this product
  attributedAt       DateTime?

  @@index([shop, clickedAt])
  @@index([shop, attributedAt])
  @@index([conversationId])
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Merchant feedback submitted from the dashboard.
// Stored for audit trail; also emailed to admin@stackedboost.com on submit.
model Feedback {
  id        String   @id @default(cuid())
  shop      String                        // e.g. "trustscore-dev.myshopify.com"
  message   String                        // required free-text feedback
  email     String?                       // optional merchant reply-to email
  plan      String   @default("free")     // plan at time of submission
  createdAt DateTime @default(now())

  @@index([shop])
  @@index([createdAt])
}
